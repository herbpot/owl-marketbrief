---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const reports = (await getCollection('reports'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);
---
<Base title="시장의 맥박을 데이터로 읽다">
  <section class="hero">
    <div class="container">
      <h1>시장의 맥박을<br/><span class="grad">데이터로 읽다.</span></h1>
      <p class="lead">노이즈를 걷어내고 흐름의 신호만 남깁니다. 매크로·주식·암호화폐를 관통하는 프리미엄 투자 리포트.</p>
      <div class="stats">
        <div class="stat"><div class="num">1,240+</div><div class="label">누적 발행 리포트</div></div>
        <div class="stat"><div class="num">38K</div><div class="label">구독자</div></div>
        <div class="stat"><div class="num">87%</div><div class="label">신호 적중률</div></div>
      </div>
    </div>
  </section>

  <section class="section" id="reports">
    <div class="container">
      <h2>최신 리포트</h2>
      <p class="sub">이번 주 시장을 관통하는 인사이트.</p>
      <div class="grid">
        {reports.map((r) => (
          <a class="card" href={`/owl-marketbrief/reports/${r.id}`}>
            <span class="tag">{r.data.type}</span>
            <h3>{r.data.title}</h3>
            <p>{r.data.summary}</p>
            <div class="meta"><span>{r.data.date}</span><span>→</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta">
        <div>
          <h2>용어가 막막하다면</h2>
          <p class="sub">핵심 투자 용어를 한 곳에서. <a href="/owl-marketbrief/glossary" class="link">용어집 보기 →</a></p>
        </div>
        <a href="/owl-marketbrief/pro" class="btn">Pro 둘러보기</a>
      </div>
    </div>
  </section>
</Base>
