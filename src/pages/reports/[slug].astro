---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---
<Base title={d.title}>
  <article class="prose">
    <a href="/owl-marketbrief/" class="back">← 전체 리포트</a>
    <div class="tags">
      <span class="tag">{d.type}</span>
      {d.proOnly && <span class="tag pro">Pro</span>}
    </div>
    <h1>{d.title}</h1>
    <p class="date">{d.date}</p>
    <p class="lede">{d.summary}</p>
    <Content />
    <div class="glosslink">관련 용어는 <a href="/owl-marketbrief/glossary" class="link">용어집</a>에서 확인하세요.</div>
  </article>
</Base>
