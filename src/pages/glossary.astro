---
import Base from '../layouts/Base.astro';

const terms = [
  { ko: '밸류업', en: 'Value-up', desc: '기업가치 제고 정책. 자사주 소각·배당 확대 등 주주환원을 유도해 코리아 디스카운트를 해소한다.' },
  { ko: '코리아 디스카운트', en: 'Korea Discount', desc: '한국 증시가 펀더멘털 대비 낮게 평가받는 현상. 지배구조·주주환원 미흡이 원인으로 지목된다.' },
  { ko: 'PBR', en: 'Price Book Ratio', desc: '주가순자산비율. 주가를 주당순자산가치로 나눈 값. 1.0 이하면 장부가치보다 싸게 거래됨.' },
  { ko: 'CPI', en: 'Consumer Price Index', desc: '소비자물가지수. 인플레이션 측정의 핵심 지표로, 금리 정책에 직접적 영향을 준다.' },
  { ko: 'FOMC', en: 'Federal Open Market Committee', desc: '미 연방공개시장위원회. 기준금리를 결정하는 연준의 핵심 의사결정 기구.' },
  { ko: '알트 시즌', en: 'Alt Season', desc: '비트코인 외 알트코인이 시장을 주도하는 구간. 보통 BTC 도미넌스 하락과 동행한다.' },
  { ko: '온체인', en: 'On-chain', desc: '블록체인 상에 기록된 실제 거래·보유 데이터를 분석해 시장 심리를 읽는 기법.' },
  { ko: 'ETF', en: 'Exchange Traded Fund', desc: '상장지수펀드. 지수·원자재·비트코인 등을 추종하며 거래소에서 주식처럼 거래된다.' },
  { ko: '자산배분', en: 'Asset Allocation', desc: '주식·채권·실물자산 간 비중 조절로 리스크를 분산하는 포트폴리오 전략.' },
  { ko: '바벨 전략', en: 'Barbell Strategy', desc: '안전자산과 고위험자산에 극단적으로 비중을 두고 중위험 구간을 비우는 배분법.' },
];
---
<Base title="투자 용어집">
  <div class="gloss">
    <h1>용어집</h1>
    <p class="sub">리포트에 자주 등장하는 핵심 용어를 한 줄로 정리했습니다.</p>
    <dl>
      {terms.map((t) => (
        <div class="term">
          <dt>{t.ko}<span class="en">{t.en}</span></dt>
          <dd>{t.desc}</dd>
        </div>
      ))}
    </dl>
  </div>
</Base>
