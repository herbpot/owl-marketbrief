---
// 흐름 (HEUREUM) — A트랙 레이아웃
// 인우 님 브랜드 픽 시 아래 BRAND / BRAND_EN / BASE 만 교체하면 끝.
const { title, description = '시장의 맥박을 데이터로 읽는 프리미엄 투자 리포트' } = Astro.props;
const BRAND = '흐름';
const BRAND_EN = 'HEUREUM';
const BASE = '/owl-marketbrief';
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} · {BRAND}</title>
  <meta name="description" content={description} />
  <meta property="og:site_name" content={BRAND} />
  <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
  <style is:global>
    :root {
      --accent-from: #6366f1;
      --accent-to: #8b5cf6;
      --gradient: linear-gradient(135deg, var(--accent-from), var(--accent-to));
      --bg: #ffffff;
      --fg: #1a2233;
      --muted: #52607a;
      --line: #ececf1;
      --surface: #fbfbfd;
      --radius: 16px;
      --container: 1040px;
      --shadow-sm: 0 1px 2px rgba(16,18,30,.04), 0 4px 16px rgba(16,18,30,.04);
      --shadow-lg: 0 8px 30px rgba(16,18,30,.10);
    }
    * { box-sizing: border-box; }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; text-rendering: optimizeLegibility; scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      background: var(--bg);
      color: var(--fg);
      letter-spacing: -0.02em;
      line-height: 1.6;
    }
    a { color: inherit; text-decoration: none; }
    .container { max-width: var(--container); margin: 0 auto; padding: 0 24px; }

    /* Header — sticky glass */
    .site-header { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(180%) blur(12px); -webkit-backdrop-filter: saturate(180%) blur(12px); background: rgba(255,255,255,0.72); border-bottom: 1px solid var(--line); }
    .header-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .wordmark { display: flex; align-items: baseline; gap: 8px; }
    .wm-ko { font-size: 20px; font-weight: 800; letter-spacing: -0.04em; background: var(--gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .wm-en { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); font-weight: 600; }
    .nav { display: flex; gap: 28px; font-size: 15px; font-weight: 600; color: var(--muted); }
    .nav a { transition: color .15s ease; }
    .nav a:hover { color: var(--fg); }
    .nav-pro { color: var(--accent-to) !important; }

    /* Hero */
    .hero { padding: 104px 0 72px; }
    .hero h1 { font-size: clamp(40px, 7vw, 72px); font-weight: 850; letter-spacing: -0.05em; line-height: 1.04; margin: 0 0 22px; }
    .hero .grad { background: var(--gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .hero .lead { font-size: 19px; color: var(--muted); max-width: 580px; margin: 0 0 44px; }
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .stat { padding: 28px 24px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .stat .num { font-size: 42px; font-weight: 850; letter-spacing: -0.04em; background: var(--gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .stat .label { font-size: 14px; color: var(--muted); margin-top: 8px; }

    /* Sections + cards */
    .section { padding: 80px 0; }
    .section h2 { font-size: 30px; font-weight: 800; letter-spacing: -0.04em; margin: 0 0 6px; }
    .section .sub { color: var(--muted); margin: 0 0 36px; font-size: 16px; }
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .card { display: block; padding: 24px; border: 1px solid var(--line); border-radius: var(--radius); background: #fff; box-shadow: var(--shadow-sm); transition: transform .2s ease, box-shadow .2s ease; }
    .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .card .tag { display: inline-block; font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: 999px; background: color-mix(in srgb, var(--accent-to) 14%, var(--surface)); color: var(--accent-to); margin-bottom: 14px; }
    .card h3 { font-size: 18px; font-weight: 750; margin: 0 0 10px; line-height: 1.35; }
    .card p { font-size: 14px; color: var(--muted); margin: 0 0 16px; }
    .card .meta { font-size: 13px; color: var(--muted); display: flex; justify-content: space-between; align-items: center; }
    .card .meta .roi { color: var(--accent-to); font-weight: 700; }

    /* CTA */
    .cta { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 40px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .cta h2 { margin-bottom: 4px; }
    .link { color: var(--accent-to); font-weight: 700; }
    .btn { display: inline-block; padding: 13px 26px; border-radius: 999px; background: var(--gradient); color: #fff; font-weight: 700; font-size: 15px; box-shadow: var(--shadow-sm); transition: transform .2s ease, box-shadow .2s ease; white-space: nowrap; }
    .btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }

    /* Prose (report pages) */
    .prose { max-width: 720px; margin: 0 auto; padding: 72px 24px 40px; }
    .prose .back { display: inline-block; font-size: 14px; color: var(--muted); margin-bottom: 24px; }
    .prose .back:hover { color: var(--fg); }
    .prose .tags { display: flex; gap: 8px; margin-bottom: 14px; }
    .prose .tag { font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: 999px; background: color-mix(in srgb, var(--accent-to) 14%, var(--surface)); color: var(--accent-to); }
    .prose .tag.pro { background: var(--gradient); color: #fff; }
    .prose h1 { font-size: clamp(28px, 5vw, 40px); font-weight: 850; letter-spacing: -0.04em; line-height: 1.2; margin: 0 0 12px; }
    .prose .date { color: var(--muted); font-size: 14px; margin: 0 0 20px; }
    .prose .lede { font-size: 18px; color: var(--muted); margin: 0 0 36px; padding-bottom: 28px; border-bottom: 1px solid var(--line); }
    .prose h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.03em; margin: 40px 0 14px; }
    .prose h3 { font-size: 19px; font-weight: 750; margin: 28px 0 10px; }
    .prose p { font-size: 16px; color: #1a2233; }
    .prose ul, .prose ol { font-size: 16px; color: #1a2233; padding-left: 22px; }
    .prose li { margin: 6px 0; }
    .prose blockquote { margin: 24px 0; padding: 14px 18px; border-left: 3px solid var(--accent-to); background: var(--surface); border-radius: 0 10px 10px 0; color: var(--muted); font-size: 15px; }
    .prose table { width: 100%; border-collapse: collapse; margin: 28px 0; font-size: 14px; }
    .prose th, .prose td { border: 1px solid var(--line); padding: 12px 14px; text-align: left; }
    .prose th { background: var(--surface); font-weight: 700; }
    .prose .glosslink { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--line); color: var(--muted); font-size: 15px; }
    .factbox { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; margin: 32px 0; }
    .fact { padding: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .fact .k { font-size: 12px; color: var(--muted); }
    .fact .v { font-size: 22px; font-weight: 800; margin-top: 6px; letter-spacing: -0.03em; }
    .fact .v.grad { background: var(--gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .risk-LOW { color: #059669; }
    .risk-MEDIUM { color: #d97706; }
    .risk-HIGH { color: #dc2626; }

    /* Glossary */
    .gloss { max-width: 760px; margin: 0 auto; padding: 72px 24px 40px; }
    .gloss h1 { font-size: 36px; font-weight: 850; letter-spacing: -0.04em; margin: 0 0 8px; }
    .gloss .sub { color: var(--muted); margin: 0 0 40px; }
    .term { padding: 22px 0; border-bottom: 1px solid var(--line); }
    .term dt { font-size: 18px; font-weight: 750; margin-bottom: 6px; }
    .term dt .en { font-size: 13px; color: var(--muted); font-weight: 600; margin-left: 8px; letter-spacing: 0.02em; }
    .term dd { margin: 0; color: var(--muted); font-size: 15px; }

    /* Pro */
    .pro { max-width: 920px; margin: 0 auto; padding: 88px 24px 40px; text-align: center; }
    .pro h1 { font-size: clamp(34px, 6vw, 52px); font-weight: 850; letter-spacing: -0.04em; margin: 0 0 16px; }
    .pro .lead { color: var(--muted); font-size: 18px; max-width: 520px; margin: 0 auto 48px; }
    .plans { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; text-align: left; max-width: 680px; margin: 0 auto; }
    .plan { padding: 32px; border: 1px solid var(--line); border-radius: var(--radius); background: #fff; box-shadow: var(--shadow-sm); }
    .plan.featured { border-color: transparent; background: var(--gradient); color: #fff; box-shadow: var(--shadow-lg); }
    .plan .name { font-size: 15px; font-weight: 700; color: var(--muted); }
    .plan.featured .name { color: rgba(255,255,255,.85); }
    .plan .price { font-size: 38px; font-weight: 850; letter-spacing: -0.04em; margin: 10px 0; }
    .plan .price small { font-size: 15px; font-weight: 600; color: var(--muted); }
    .plan.featured .price small { color: rgba(255,255,255,.8); }
    .plan ul { list-style: none; padding: 0; margin: 20px 0 0; }
    .plan li { font-size: 14px; padding: 8px 0; border-top: 1px solid var(--line); }
    .plan.featured li { border-top-color: rgba(255,255,255,.2); }
    .plan .cta-btn { display: block; text-align: center; margin-top: 24px; padding: 12px; border-radius: 999px; font-weight: 700; font-size: 15px; background: var(--surface); color: var(--fg); transition: transform .2s ease; }
    .plan.featured .cta-btn { background: #fff; color: var(--accent-to); }
    .plan .cta-btn:hover { transform: translateY(-2px); }

    /* Footer */
    .site-footer { border-top: 1px solid var(--line); padding: 40px 0; margin-top: 40px; color: var(--muted); font-size: 14px; }
    .site-footer .wm-ko { font-weight: 800; background: var(--gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .site-footer p { margin: 8px 0 0; max-width: 540px; }

    @keyframes fadeup { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
    .hero, .section, .prose, .gloss, .pro { animation: fadeup .5s ease both; }

    /* Dark mode — prefers-color-scheme */
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0b0f1a;
        --surface: #131a2a;
        --fg: #e8edf5;
        --muted: #9aa7bd;
        --line: #232c3d;
        --shadow-sm: 0 1px 2px rgba(0,0,0,.28), 0 4px 16px rgba(0,0,0,.28);
        --shadow-lg: 0 8px 30px rgba(0,0,0,.45);
      }
      .site-header { background: rgba(11,15,26,0.72); }
      body { color: var(--fg); }
      .card, .plan, .stat, .cta, .fact, .prose blockquote, .prose th { background: var(--surface); }
      .card .tag, .prose .tag { background: color-mix(in srgb, var(--accent-to) 18%, var(--surface)); }
      .plan .cta-btn { background: var(--surface); }
      .prose p, .prose ul, .prose ol { color: #d7deea; }
    }

    @media (max-width: 760px) {
      .grid, .stats, .plans { grid-template-columns: 1fr; }
      .hero { padding: 64px 0 48px; }
      .section { padding: 56px 0; }
      .nav { gap: 16px; font-size: 14px; }
      .cta { flex-direction: column; align-items: flex-start; padding: 28px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href={`${BASE}/`} class="wordmark">
        <span class="wm-ko">{BRAND}</span>
        <span class="wm-en">{BRAND_EN}</span>
      </a>
      <nav class="nav">
        <a href={`${BASE}/#reports`}>리포트</a>
        <a href={`${BASE}/glossary`}>용어집</a>
        <a href={`${BASE}/pro`} class="nav-pro">Pro</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container">
      <span class="wm-ko">{BRAND}</span>
      <p>본 사이트의 투자 정보는 참고용이며, 투자 결정과 그에 따른 책임은 투자자 본인에게 있습니다.</p>
    </div>
  </footer>
</body>
</html>
